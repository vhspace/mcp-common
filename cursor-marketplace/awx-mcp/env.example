# TRANSPORT=stdio
# HOST=127.0.0.1
# PORT=8000
# MCP_HTTP_ACCESS_TOKEN=your_mcp_access_token_here
# VERIFY_SSL=true
# TIMEOUT_SECONDS=30
# LOG_LEVEL=INFO










