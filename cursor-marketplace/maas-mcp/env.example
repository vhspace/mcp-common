# MAAS MCP Server Configuration
# Copy this file to .env and fill in your actual values

# ===== MAAS Configuration =====
# Option 1: Single MAAS instance (recommended for most users)
MAAS_URL=https://maas.example.com/MAAS
MAAS_API_KEY=consumer_key:consumer_token:secret

# Option 2: Multiple MAAS instances via JSON (advanced)
# MAAS_INSTANCES='{"prod": {"url": "https://maas-prod.example.com/MAAS", "api_key": "key1:token1:secret1"}, "dev": {"url": "https://maas-dev.example.com/MAAS", "api_key": "key2:token2:secret2"}}'

# Option 3: Multiple MAAS instances via per-site env vars
# All vars start with MAAS_ so site names with leading digits (e.g. 5C_OH1) are valid.
# MAAS_ORI_URL=https://maas-ori.example.com/MAAS
# MAAS_ORI_API_KEY=key1:token1:secret1
# MAAS_CENTRAL_URL=https://maas-central.example.com/MAAS
# MAAS_CENTRAL_API_KEY=key2:token2:secret2
# MAAS_5C_OH1_URL=https://maas-5c-oh1.example.com/MAAS
# MAAS_5C_OH1_API_KEY=key3:token3:secret3

# ===== NetBox Integration (Optional) =====
# Option 1: Direct NetBox API access
# NETBOX_URL=https://netbox.example.com/
# NETBOX_TOKEN=your_netbox_api_token

# Option 2: Use NetBox MCP server (if you have one configured)
# NETBOX_MCP_SERVER=netbox

# ===== Transport Settings =====
# TRANSPORT=stdio          # or "http" for HTTP transport
# HOST=127.0.0.1          # For HTTP transport only
# PORT=8000               # For HTTP transport only

# ===== HTTP Transport Authentication (Required for HTTP transport) =====
# MCP_HTTP_ACCESS_TOKEN=your_secret_token_here

# ===== Security Settings =====
# VERIFY_SSL=true         # Set to false to disable SSL verification (not recommended)
# TIMEOUT_SECONDS=30      # HTTP client timeout

# ===== Logging =====
# LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ===== Getting Your MAAS API Key =====
# 1. Log into MAAS web UI
# 2. Go to your user preferences (top right menu)
# 3. Click "API keys" tab
# 4. Click "Generate MAAS API key"
# 5. Copy the key (format: consumer_key:consumer_token:secret)
