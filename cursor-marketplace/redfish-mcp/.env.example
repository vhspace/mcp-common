# Redfish MCP Configuration

# Target Redfish/BMC endpoint
REDFISH_IP=192.168.196.54

# Credentials
REDFISH_USER=admin
REDFISH_PASSWORD=your_password_here

# Preferred pattern for scoped credentials (examples):
# HOST_REDFISH_USER=admin
# HOST_REDFISH_PASSWORD=your_host_password_here
# ORI_REDFISH_USER=admin
# ORI_REDFISH_PASSWORD=your_ori_password_here

# Integration Testing
# Set to "true" to enable write operations in tests (DANGEROUS - modifies BMC settings!)
ENABLE_WRITE_TESTS=false
