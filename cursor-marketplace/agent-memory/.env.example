# LLM Provider: "anthropic", "openai", or "together"
LLM_PROVIDER=anthropic

# Anthropic API key — used for LLM calls (entity extraction, graph ops)
ANTHROPIC_API_KEY=

# Embedding Provider: "voyage" (Anthropic ecosystem), "openai", or "together"
EMBEDDING_PROVIDER=voyage

# Voyage AI API key — get free at https://dash.voyageai.com/
# Voyage is Anthropic's recommended embedding partner
VOYAGE_API_KEY=

# Embedding model
# Voyage: voyage-3-large, voyage-3-lite, voyage-code-3
# OpenAI: text-embedding-3-small, text-embedding-3-large
# Together: BAAI/bge-large-en-v1.5
EMBEDDING_MODEL=voyage-3-large

# LLM model for entity extraction and graph operations
# Anthropic: claude-sonnet-4-6, claude-haiku-4-20250514
# OpenAI: gpt-5.2, gpt-4.1-mini
# Together: meta-llama/Llama-4-Maverick-17B-128E-Instruct-FP8
MODEL_NAME=claude-sonnet-4-6

# --- Optional / Alternative providers ---
OPENAI_API_KEY=
TOGETHER_API_KEY=
EMBEDDING_API_KEY=

# Group ID scoping memories to a team or project
GROUP_ID=together-ops

# Host path to your workspace root (mounted into container as /workspace)
HOST_WORKSPACE=/path/to/your/workspace
