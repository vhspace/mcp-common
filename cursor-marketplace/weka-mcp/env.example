# Weka MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Weka cluster host URL
WEKA_HOST=https://weka01:14000

# Required: Weka cluster credentials
WEKA_USERNAME=admin
WEKA_PASSWORD=your-password-here

# Optional: API base path (default: /api/v2)
API_BASE_PATH=/api/v2

# Optional: SSL verification (default: true)
VERIFY_SSL=true

# Optional: HTTP client timeout in seconds (default: 30)
TIMEOUT_SECONDS=30

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Optional: MCP transport (stdio or http, default: stdio)
TRANSPORT=stdio

# Optional: HTTP server settings (only used if TRANSPORT=http)
HOST=127.0.0.1
PORT=8000

# Optional: HTTP access token (required if TRANSPORT=http)
# MCP_HTTP_ACCESS_TOKEN=your-http-access-token-here
