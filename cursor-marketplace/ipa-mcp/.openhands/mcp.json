{
  "mcpServers": {
    "ipa-mcp": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/vhspace/ipa-mcp@v1.1.1",
        "ipa-mcp"
      ],
      "env": {
        "IPA_HOST": "${IPA_HOST}",
        "IPA_USERNAME": "${IPA_USERNAME}",
        "IPA_PASSWORD": "${IPA_PASSWORD}",
        "IPA_VERIFY_SSL": "${IPA_VERIFY_SSL:-false}"
      }
    }
  }
}
