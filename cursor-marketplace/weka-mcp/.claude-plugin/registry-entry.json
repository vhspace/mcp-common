{
  "schemaVersion": 1,
  "name": "weka-mcp",
  "description": "MCP server for Weka storage system management and monitoring",
  "version": "0.6.0",
  "repository": "https://github.com/vhspace/weka-mcp",
  "license": "Apache-2.0",
  "author": {
    "name": "Together AI"
  },
  "keywords": [
    "filesystem",
    "mcp",
    "storage",
    "weka"
  ],
  "categories": [
    "infrastructure",
    "storage"
  ],
  "tags": [
    "capacity",
    "cluster",
    "filesystem",
    "weka"
  ],
  "mcpServer": {
    "command": "uvx",
    "args": [
      "--from",
      "git+https://github.com/vhspace/weka-mcp@v0.6.0",
      "weka-mcp"
    ],
    "env": {
      "WEKA_HOST": "${WEKA_HOST}",
      "WEKA_PASSWORD": "${WEKA_PASSWORD}"
    }
  },
  "pluginPath": ".claude-plugin/plugin.json"
}
