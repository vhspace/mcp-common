{
  "name": "agent-memory",
  "description": "Long-term temporal knowledge graph memory for AI agents \u2014 search, store, and evolve operational knowledge across sessions",
  "version": "1.1.0",
  "author": {
    "name": "Together AI"
  },
  "repository": "https://github.com/vhspace/agent-memory",
  "license": "Apache-2.0",
  "keywords": [
    "mcp",
    "memory",
    "knowledge-graph",
    "graphiti",
    "neo4j",
    "temporal"
  ],
  "mcpServers": {
    "agent-memory": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/vhspace/agent-memory@v1.1.0",
        "agent-memory"
      ],
      "env": {
        "NEO4J_URI": "${NEO4J_URI}",
        "NEO4J_USER": "${NEO4J_USER}",
        "NEO4J_PASSWORD": "${NEO4J_PASSWORD}",
        "LLM_PROVIDER": "${LLM_PROVIDER}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "TOGETHER_API_KEY": "${TOGETHER_API_KEY}",
        "MODEL_NAME": "${MODEL_NAME}",
        "EMBEDDING_PROVIDER": "${EMBEDDING_PROVIDER}",
        "EMBEDDING_MODEL": "${EMBEDDING_MODEL}"
      }
    }
  },
  "skills": "./skills/",
  "rules": "./rules/",
  "hooks": "./hooks/hooks.json"
}
