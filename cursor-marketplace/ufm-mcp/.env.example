UFM_URL=https://172.19.2.60/
UFM_TOKEN=REPLACE_WITH_TOKEN
UFM_API_BASE_PATH=/ufmRestV3
UFM_RESOURCES_BASE_PATH=/ufmRestV3
# Logs are typically under /ufmRestV3/app/logs for token auth
UFM_LOGS_BASE_PATH=/ufmRestV3
# History file downloads
UFM_WEB_BASE_PATH=/ufm_web
# System dump endpoint + job polling (per NVIDIA docs)
UFM_BACKUP_BASE_PATH=/ufmRestV3
UFM_JOBS_BASE_PATH=/ufmRestV3
VERIFY_SSL=false
TIMEOUT_SECONDS=30
TRANSPORT=stdio
# If using TRANSPORT=http (not recommended without a proxy/TLS):
# MCP_HTTP_ACCESS_TOKEN=REPLACE_WITH_ACCESS_TOKEN

# --- Multi-site examples (single MCP process) ---
# UFM_DEFAULT_SITE=5c_oh1
# UFM_5C_OH1_URL=https://172.26.3.60/
# UFM_5C_OH1_TOKEN=REPLACE_WITH_OH1_TOKEN
# UFM_5C_MD1_URL=https://172.26.4.60/
# UFM_5C_MD1_TOKEN=REPLACE_WITH_MD1_TOKEN
# Optional aliases for site selection:
# UFM_SITE_ALIASES_JSON={"oh1":"5c_oh1","md1":"5c_md1","us-east-3":"5c_oh1","us-central-3":"5c_md1"}

