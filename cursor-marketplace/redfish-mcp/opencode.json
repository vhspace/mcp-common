{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "redfish-mcp": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/vhspace/redfish-mcp@v2.11.1",
        "redfish-mcp"
      ],
      "environment": {
        "REDFISH_USER": "${REDFISH_USER}",
        "REDFISH_PASSWORD": "${REDFISH_PASSWORD}",
        "VERIFY_SSL": "${VERIFY_SSL:-true}"
      },
      "enabled": true
    }
  }
}
