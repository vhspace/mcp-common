{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Redfish Hardware Database Entry",
    "description": "Schema for hardware documentation database entries",
    "type": "object",
    "required": [
        "version",
        "hardware"
    ],
    "properties": {
        "version": {
            "type": "string",
            "description": "Version of this hardware entry (semver)",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "last_updated": {
            "type": "string",
            "description": "Date when this entry was last updated (YYYY-MM-DD)",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "hardware": {
            "type": "object",
            "required": [
                "vendor",
                "model"
            ],
            "properties": {
                "vendor": {
                    "type": "string",
                    "description": "Hardware manufacturer (e.g., Supermicro, Dell, HPE)"
                },
                "family": {
                    "type": "string",
                    "description": "Product family (e.g., PIO, PowerEdge, ProLiant)"
                },
                "model": {
                    "type": "string",
                    "description": "Full model number"
                },
                "description": {
                    "type": "string",
                    "description": "Human-readable description"
                },
                "socket": {
                    "type": "string",
                    "description": "CPU socket type (e.g., AMD EPYC 9004, Intel Xeon)"
                },
                "gpu_slots": {
                    "type": "integer",
                    "description": "Number of GPU slots"
                },
                "max_memory": {
                    "type": "string",
                    "description": "Maximum memory capacity (e.g., 4TB DDR5)"
                },
                "form_factor": {
                    "type": "string",
                    "description": "Server form factor (e.g., 1U, 2U, Multi-node)"
                },
                "pcie_lanes": {
                    "type": "integer",
                    "description": "Total PCIe lanes available"
                },
                "motherboard": {
                    "type": "string",
                    "description": "Motherboard model number"
                }
            }
        },
        "model_variant_info": {
            "type": "object",
            "description": "Explanation of model naming and variants for AI context",
            "properties": {
                "prefix_meaning": {
                    "type": "string",
                    "description": "What the model prefix indicates (e.g., AS=A+ Server, PIO=Plug-In Module)"
                },
                "suffix_meaning": {
                    "type": "string",
                    "description": "What the model suffix indicates (e.g., -NODE=multi-node module, -1-OI021=custom config)"
                },
                "hardware_type": {
                    "type": "string",
                    "enum": ["standalone", "multi-node-module", "blade", "rackmount"],
                    "description": "Physical deployment type"
                },
                "deployment_notes": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "How this hardware is typically deployed"
                },
                "related_variants": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "model": {
                                "type": "string"
                            },
                            "difference": {
                                "type": "string"
                            }
                        }
                    },
                    "description": "Similar models and how they differ"
                },
                "comparison_table": {
                    "type": "object",
                    "description": "Comparison with related variants",
                    "properties": {
                        "deployment": {
                            "type": "string"
                        },
                        "power_supplies": {
                            "type": "string"
                        },
                        "management": {
                            "type": "string"
                        },
                        "density": {
                            "type": "string"
                        },
                        "flexibility": {
                            "type": "string"
                        },
                        "cost_per_node": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "research_notes": {
            "type": "object",
            "description": "How to find and research documentation for this hardware",
            "properties": {
                "vendor_naming_guide": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL to vendor's product naming convention guide"
                },
                "search_keywords": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Effective search terms for finding documentation"
                },
                "doc_discovery_method": {
                    "type": "string",
                    "description": "How documentation was found (e.g., 'Web search for model + specs', 'Vendor portal', 'Redfish system info')"
                },
                "last_verified": {
                    "type": "string",
                    "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
                    "description": "When URLs and information were last verified"
                },
                "notes": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Additional research notes for AI agents"
                }
            }
        },
        "bios_versions": {
            "type": "object",
            "description": "Known BIOS versions with details",
            "patternProperties": {
                ".*": {
                    "type": "object",
                    "properties": {
                        "release_date": {
                            "type": "string",
                            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
                        },
                        "status": {
                            "type": "string",
                            "enum": [
                                "latest",
                                "stable",
                                "beta",
                                "deprecated"
                            ]
                        },
                        "changes": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "known_issues": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "recommended_settings": {
                            "type": "object",
                            "description": "BIOS settings recommended for this version"
                        }
                    }
                }
            }
        },
        "documentation": {
            "type": "object",
            "description": "Documentation URLs",
            "properties": {
                "manual": {
                    "type": "string",
                    "format": "uri"
                },
                "bios_guide": {
                    "type": "string",
                    "format": "uri"
                },
                "firmware": {
                    "type": "string",
                    "format": "uri"
                },
                "support": {
                    "type": "string",
                    "format": "uri"
                },
                "quick_start": {
                    "type": "string",
                    "format": "uri"
                }
            }
        },
        "gpu_optimization": {
            "type": "object",
            "description": "GPU-specific optimization information",
            "properties": {
                "notes": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "critical_settings": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "recommended_for_workload": {
                    "type": "object",
                    "description": "Workload-specific BIOS settings"
                }
            }
        },
        "known_configurations": {
            "type": "array",
            "description": "Known working configurations",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "validated": {
                        "type": "boolean"
                    },
                    "bios_version": {
                        "type": "string"
                    },
                    "notes": {
                        "type": "string"
                    }
                }
            }
        }
    }
}
